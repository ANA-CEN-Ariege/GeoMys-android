<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Carte -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Réticule de positionnement -->
    <FrameLayout
        android:id="@+id/reticule"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:pointerIcon="crosshair"
        android:visibility="gone">

        <!-- Lignes horizontale et verticale + cercle central -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:background="#DDFF3333" />

        <View
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="#DDFF3333" />

        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:background="@drawable/reticule_circle" />

        <View
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_gravity="center"
            android:background="@drawable/reticule_dot" />
    </FrameLayout>

    <!-- Bandeau instruction positionnement -->
    <LinearLayout
        android:id="@+id/bandeau_positionnement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center"
        android:paddingTop="60dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_bandeau_positionnement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bandeau_dark"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="@string/positionner_observation"
            android:textColor="@android:color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bouton terminer / quitter — petit cercle vert avec coche, HAUT DROITE. -->
    <ImageButton
        android:id="@+id/btn_retour"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Terminer la sortie"
        android:scaleType="fitCenter"
        android:src="@drawable/coche" />

    <!-- Sélecteur de mode de saisie géométrique : centré verticalement, côté gauche.
         Visible uniquement quand on positionne une nouvelle observation. Le bouton
         actif est mis en évidence via une teinte de fond. Par défaut : point. -->
    <LinearLayout
        android:id="@+id/ll_mode_geom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_mode_point"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Saisir un point"
            android:src="@drawable/ic_pin_drop" />

        <ImageButton
            android:id="@+id/btn_mode_line"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Saisir une ligne"
            android:src="@drawable/ic_geom_line" />

        <ImageButton
            android:id="@+id/btn_mode_polygon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Saisir un polygone"
            android:src="@drawable/ic_geom_polygon" />
    </LinearLayout>

    <!-- Stack de contrôles carte — empilés verticalement en BAS À DROITE de la carte. De
         haut en bas : recentrage GPS, boussole (toggle rotation), fond de carte. Le
         marginBottom décale le stack au-dessus du panneau bas (~84dp pour panneau_controle
         ou panneau_validation_position) plus l'info_barre éventuelle. -->
    <LinearLayout
        android:id="@+id/ll_carte_controles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="100dp"
        android:orientation="vertical">

        <!-- Bouton centrage (toggle suivi position). -->
        <ImageButton
            android:id="@+id/btn_centrer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_circle_white"
            android:contentDescription="Centrer"
            android:src="@drawable/ic_location_on" />

        <!-- Boussole (toggle rotation carte). -->
        <fr.ariegenature.geonat.ui.CompassView
            android:id="@+id/compass"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:elevation="4dp" />

        <!-- Bouton fond de carte (rotation des 4 fonds OSM/IGN). -->
        <ImageButton
            android:id="@+id/btn_fond_carte"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Changer fond"
            android:src="@drawable/ic_map" />
    </LinearLayout>

    <!-- Barre d'info parcours -->
    <LinearLayout
        android:id="@+id/info_barre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/barre_info_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_walk"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tv_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="24dp"
            android:text="0 m"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/oiseaux"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tv_nb_obs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="0 obs."
            android:textColor="@android:color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Overlay envoi GeoNature -->
    <LinearLayout
        android:id="@+id/overlay_envoi"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Envoi vers GeoNature…"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Panneau contrôle normal. Trois cases pondérées (poids 1 chacune) qui se partagent
         équitablement la largeur. Quand le wrapper de Play est masqué (cf TraceFragment :
         enregistrement de trace désactivé), les deux autres récupèrent l'espace et se
         retrouvent automatiquement centrées sur leur moitié. -->
    <LinearLayout
        android:id="@+id/panneau_controle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <!-- Case Play -->
        <FrameLayout
            android:id="@+id/wrap_parcours"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_parcours"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_circle_green"
                android:contentDescription="Parcours"
                android:src="@drawable/ic_play"
                android:tint="@android:color/white" />
        </FrameLayout>

        <!-- Case Observation -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_observation"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_circle_blue"
                android:contentDescription="Observation"
                android:src="@drawable/ic_add"
                android:tint="@android:color/white" />
        </FrameLayout>

        <!-- Case Liste avec badge -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">
                <ImageButton
                    android:id="@+id/btn_liste"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/btn_circle_blue"
                    android:contentDescription="Liste"
                    android:src="@drawable/ic_list"
                    android:tint="@android:color/white" />
                <TextView
                    android:id="@+id/liste_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:background="@drawable/badge_orange"
                    android:minWidth="18dp"
                    android:paddingHorizontal="4dp"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Panneau validation positionnement -->
    <LinearLayout
        android:id="@+id/panneau_validation_position"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/panel_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_annuler_position"
            style="@style/Widget.GeoNat.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@android:color/darker_gray"
            android:text="@string/annuler"
            android:textColor="@android:color/white" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- "Ajouter sommet" : visible uniquement en mode line/polygon. Pose un sommet
             à la position courante du réticule et l'ajoute à la géométrie en cours. -->
        <Button
            android:id="@+id/btn_ajouter_sommet"
            style="@style/Widget.GeoNat.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="+ Sommet"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_valider_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/colorPrimary"
            android:text="@string/valider_position"
            android:textColor="@android:color/white" />
    </LinearLayout>
</FrameLayout>