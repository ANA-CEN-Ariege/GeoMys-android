<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Carte (cachée en mode config, affichée quand la saisie démarre) -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Bandeau de navigation "🏠 › Saisie mono-taxons" (flottant, haut gauche). Reste
         visible en mode config comme en mode carte ; le panneau de config décale son titre
         (paddingTop) pour passer dessous. -->
    <include
        android:id="@+id/bandeau_saisie"
        layout="@layout/view_bandeau_saisie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp" />

    <!-- Réticule (visible en mode actif) -->
    <FrameLayout
        android:id="@+id/reticule"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:background="#DDFF3333" />

        <View
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="#DDFF3333" />

        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:background="@drawable/reticule_circle" />

        <View
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_gravity="center"
            android:background="@drawable/reticule_dot" />
    </FrameLayout>

    <!-- Bouton terminer / quitter — petit cercle vert avec coche, en HAUT À DROITE.
         Visible uniquement en mode actif (sur la carte) ; masqué en mode config (écran de
         sélection du taxon) via updateModeUI() côté fragment. -->
    <ImageButton
        android:id="@+id/btn_retour"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Terminer la saisie"
        android:scaleType="fitCenter"
        android:src="@drawable/coche" />

    <!-- Compteur session (haut centre, mode actif) — n obs. enregistrée(s) cumulées. -->
    <TextView
        android:id="@+id/tv_compteur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:background="@drawable/bandeau_dark"
        android:paddingHorizontal="14dp"
        android:paddingVertical="7dp"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Stack de contrôles carte (visible uniquement en mode actif) — empilés verticalement
         en BAS À DROITE de la carte. De haut en bas : recentrage GPS, boussole (toggle
         rotation), fond de carte. Le marginBottom décale le stack au-dessus du panneau actif
         (~180dp avec le snack de confirmation visible) pour qu'il reste accessible sans
         chevaucher le résumé / FAB d'enregistrement. -->
    <LinearLayout
        android:id="@+id/ll_carte_controles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="180dp"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Bouton re-centrage GPS — toggle suivi position (cf updateGpsLockIcon). -->
        <ImageButton
            android:id="@+id/btn_centrer_gps"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_circle_white"
            android:contentDescription="Recentrer sur ma position"
            android:src="@drawable/ic_location_on" />

        <!-- Boussole (toggle rotation carte) — espacement vertical visuel = 12dp. -->
        <fr.ariegenature.geomys.ui.CompassView
            android:id="@+id/compass"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:elevation="4dp" />

        <!-- Bouton fond de carte (rotation des 4 fonds OSM/IGN). -->
        <ImageButton
            android:id="@+id/btn_fond_carte"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Changer fond"
            android:src="@drawable/ic_map" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         PANNEAU CONFIGURATION (état initial)
         ═══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/panneau_config"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:scrollbars="none">

        <!-- Pas de fond opaque ici : le panneau de config s'affiche carte cachée, donc on
             laisse transparaître le windowBackground (dégradé bg_accueil) pour que le
             formulaire ait exactement le fond par défaut de l'app. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="84dp"
            android:paddingBottom="24dp">

            <!-- Plus de titre « Saisie rapide multi-points » ni d'icône : le bandeau de
                 navigation flottant "🏠 › Saisie mono-taxons" tient lieu d'en-tête. Le
                 paddingTop dégage la ligne des groupes taxonomiques sous le bandeau. -->

            <!-- Sélecteur de taxon -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="2dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_oiseau"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/oiseaux"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_mammifere"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/mammiferes2"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_reptile"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/reptiles2"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_batracien"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/amphibiens"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_mollusque"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/mollusques"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_poisson"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/poissons"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_insecte"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/insectes"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_invertebres"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/araignees"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_plante"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/fleurs"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_fonge"
                        style="@style/Widget.GeoMys.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/champignons2"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Switch nom scientifique + bouton Détails sur la même ligne (même disposition
                 qu'en multi-taxons). Chain horizontale spread_inside : switch ancré à start,
                 bouton à end. Le bouton "Détails" édite les champs additionnels OCCTAX_RELEVE
                 communs à toutes les obs de la session — masqué si le serveur n'en déclare aucun. -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_nom_sci"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom scientifique"
                    android:textSize="13sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_details_releve"
                    app:layout_constraintHorizontal_chainStyle="spread_inside"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Button
                    android:id="@+id/btn_details_releve"
                    style="@style/Widget.GeoMys.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="36dp"
                    android:paddingHorizontal="16dp"
                    android:text="Détails"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/switch_nom_sci"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Espèce (optionnel) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_espece"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Espèce (optionnel)"
                app:endIconDrawable="@drawable/ic_mic"
                app:endIconMode="custom"
                app:endIconContentDescription="Dictée vocale">

                <AutoCompleteTextView
                    android:id="@+id/et_espece"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:completionThreshold="1"
                    android:inputType="textCapSentences" />
            </com.google.android.material.textfield.TextInputLayout>

            <ProgressBar
                android:id="@+id/taxref_progress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_taxref_statut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Boutons détails par défaut : caractérisation + dénombrement -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_caracterisation_defaut"
                    style="@style/Widget.GeoMys.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:text="Caractérisation" />

                <Button
                    android:id="@+id/btn_denombrement_defaut"
                    style="@style/Widget.GeoMys.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="Dénombrement" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_details_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Boutons Annuler / Démarrer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_annuler_saisie"
                    style="@style/Widget.GeoMys.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Annuler" />

                <Button
                    android:id="@+id/btn_demarrer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Démarrer la saisie →" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════
         PANNEAU ACTIF (enregistrement en cours)
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panneau_actif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/panel_bg"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:visibility="gone">

        <!-- Résumé des paramètres par défaut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_taxon_icon_actif"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:src="@drawable/oiseaux" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_resume_params"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_resume_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorControlNormal"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_modifier_params"
                style="@style/Widget.GeoMys.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modifier" />
        </LinearLayout>

        <!-- Confirmation dernière observation (auto-dismiss 3s) -->
        <LinearLayout
            android:id="@+id/snack_confirmation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1A4CAF50"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_check_circle"
                app:tint="@android:color/holo_green_dark" />

            <TextView
                android:id="@+id/tv_snack_espece"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@android:color/holo_green_dark"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_snack_modifier"
                style="@style/Widget.GeoMys.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modifier"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Boutons d'action — uniquement le FAB d'enregistrement (le bouton de recentrage
             GPS est désormais dans le stack overlay carte, cf ll_carte_controles). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical|end"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_enregistrer_ici"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/btn_circle_blue"
                android:contentDescription="Enregistrer ici"
                android:src="@drawable/ic_add"
                android:tint="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
