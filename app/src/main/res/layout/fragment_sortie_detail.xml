<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Overlay envoi GeoNature -->
    <LinearLayout
        android:id="@+id/overlay_envoi"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Envoi vers GeoNature…"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Bouton retour (haut gauche). Fond blanc + flèche agrandie et teintée du bleu du
         thème pour bien ressortir sur la carte. -->
    <ImageButton
        android:id="@+id/btn_retour"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:background="@drawable/btn_circle_white"
        android:contentDescription="Retour"
        android:padding="9dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_arrow_back"
        app:tint="?attr/colorPrimary" />

    <!-- Actions (haut droite) : Envoyer vers GeoNature + Partager (GPX), boutons ronds.
         Envoyer = cercle bleu plein (action principale) ; Partager = cercle blanc, icône
         teintée du bleu du thème. -->
    <LinearLayout
        android:id="@+id/conteneur_actions_haut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:gravity="end"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btn_envoyer_gn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_circle_blue"
            android:contentDescription="Envoyer vers GeoNature"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_send"
            android:visibility="gone"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/btn_exporter"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_circle_white"
            android:contentDescription="Partager (GPX)"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_share"
            app:tint="?attr/colorPrimary" />
    </LinearLayout>

    <!-- Contrôles carte (bas droite) : changer de fond + liste des espèces. Mêmes
         icônes/style (btn_map_bg + ic_map/ic_list) que les autres écrans cartographiques. -->
    <LinearLayout
        android:id="@+id/conteneur_carte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:gravity="end"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btn_fond_carte"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Changer fond"
            android:src="@drawable/ic_map" />

        <ImageButton
            android:id="@+id/btn_liste_especes"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Liste des espèces"
            android:src="@drawable/ic_list"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
