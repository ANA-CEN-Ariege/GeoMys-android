<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/iv_taxon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="10dp"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="4dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/tv_espece"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textSize="15sp" />

        <!-- Nom scientifique sous le nom français (italique, couleur secondaire qui
             s'adapte au mode sombre). Masqué si l'espèce affichée est déjà le nom sci. -->
        <TextView
            android:id="@+id/tv_sci_nom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:textStyle="italic"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Lien de comptage « × N » : tap → écran dénombrement. Texte sombre dans un cercle blanc
         de ~24 dp (même zone 36 dp et même taille visible que le bouton info « i »). -->
    <TextView
        android:id="@+id/tv_nombre"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/bg_compteur"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:textColor="#212121"
        android:textSize="11sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btn_info"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Détails"
        android:src="@drawable/ic_info"
        app:tint="@android:color/white" />

    <ImageButton
        android:id="@+id/btn_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Supprimer"
        android:src="@drawable/ic_delete"
        app:tint="@android:color/holo_red_dark" />

</LinearLayout>
