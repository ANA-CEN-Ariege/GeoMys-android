<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/scroll_contenu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="64dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tv_titre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_contexte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@android:color/darker_gray"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/ll_formulaire"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Enregistrer la visite" />

            <!-- Bouton "Terminer" : visible UNIQUEMENT en mode "chaîne de saisies" (= quand
                 le parent est lui-même un type de saisie type visite, donc on enchaîne
                 plusieurs obs sur la même visite). Pour sortir du flow et revenir à la
                 fiche du parent. -->
            <Button
                android:id="@+id/btn_terminer"
                style="@style/Widget.GeoNat.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Terminer"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <!-- Fil d'Ariane flottant : sticky en haut, au-dessus du ScrollView. Bordure arrondie +
         ombre (elevation) pour que l'utilisateur voie nettement le contenu passer dessous. -->
    <TextView
        android:id="@+id/tv_fil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_fil_ariane"
        android:backgroundTint="?attr/colorSurfaceVariant"
        android:elevation="6dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:ignore="UnusedAttribute"
        tools:visibility="visible" />

    <!-- Plus de flèche retour : l'icône maison du fil d'Ariane assure le retour. -->
</FrameLayout>