<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Plus de bouton flèche retour : le bandeau de navigation "🏠 › Maps Manager"
         (icône maison) assure le retour à l'accueil. -->

    <!-- Supprimer le cache (haut droite), isolé : action destructive, teinte rouge. -->
    <ImageButton
        android:id="@+id/btn_vider_cache"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="8dp"
        android:background="@drawable/btn_circle_white"
        android:contentDescription="Vider le cache"
        android:src="@drawable/ic_delete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#C62828" />

    <!-- Bandeau de navigation "🏠 › Maps Manager" (entre le bouton retour et la corbeille). -->
    <include
        android:id="@+id/bandeau_saisie"
        layout="@layout/view_bandeau_saisie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="14dp"
        app:layout_constraintEnd_toStartOf="@id/btn_vider_cache"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_titre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/badge_bg"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="Cache des fonds"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bandeau_saisie" />

    <!-- Contrôles carte (bas droite, juste au-dessus du panneau bas) : changer de fond,
         cibler un protocole. Mêmes icônes/style (btn_map_bg + ic_map/ic_list) que les
         autres écrans cartographiques de l'app. -->
    <LinearLayout
        android:id="@+id/conteneur_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/panel_bas"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_centrer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Recentrer sur ma position"
            android:src="@drawable/ic_location_on" />

        <ImageButton
            android:id="@+id/btn_fond_carte"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Changer le fond de carte"
            android:src="@drawable/ic_map" />

        <!-- Masqué tant qu'on n'a pas confirmé qu'au moins un protocole est accessible
             (droits CRUVED). Révélé par CacheManagerFragment après chargement des modules. -->
        <ImageButton
            android:id="@+id/btn_protocole"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_map_bg"
            android:contentDescription="Cibler un protocole"
            android:src="@drawable/ic_list"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Zoom +/- (vertical, bas-gauche, au-dessus du panneau bas — symétrique de conteneur_actions).
         Remplace les boutons osmdroid (désactivés côté code). -->
    <LinearLayout
        android:id="@+id/ll_zoom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/panel_bas"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btn_zoom_in"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/btn_circle_white"
            android:contentDescription="Zoom avant"
            android:src="@drawable/ic_add" />

        <ImageButton
            android:id="@+id/btn_zoom_out"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_circle_white"
            android:contentDescription="Zoom arrière"
            android:src="@drawable/ic_remove" />
    </LinearLayout>

    <!-- Panneau bas : infos surface/tuiles/poids + bouton télécharger.
         Utilise le fond par défaut de l'app (dégradé accueil sombre) → texte clair. -->
    <LinearLayout
        android:id="@+id/panel_bas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?android:attr/windowBackground"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_surface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_tuiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/white_70"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_cache_utilise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_avertissement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#C62828"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_charger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Charger les tuiles" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
