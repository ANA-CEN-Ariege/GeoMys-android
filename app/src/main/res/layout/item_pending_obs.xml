<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/iv_taxon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="10dp"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/tv_espece"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:ellipsize="end"
        android:maxLines="2"
        android:paddingHorizontal="4dp"
        android:paddingVertical="6dp"
        android:textSize="15sp" />

    <!-- Chip de comptage : tap → popup pour ajuster le nombre d'individus de cette ligne -->
    <TextView
        android:id="@+id/tv_nombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:background="@drawable/chip_count_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="36dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textSize="13sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btn_edit"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Modifier le nom"
        android:src="@drawable/ic_edit"
        app:tint="?attr/colorOnSurface" />

    <ImageButton
        android:id="@+id/btn_info"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Détails"
        android:src="@drawable/ic_info"
        app:tint="?attr/colorOnSurface" />

    <ImageButton
        android:id="@+id/btn_delete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Supprimer"
        android:src="@drawable/ic_delete"
        app:tint="@android:color/holo_red_dark" />

</LinearLayout>
