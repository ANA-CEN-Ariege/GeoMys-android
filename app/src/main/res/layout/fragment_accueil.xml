<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_accueil">

    <!-- Bouton menu en haut à gauche -->
    <ImageButton
        android:id="@+id/btn_menu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Menu"
        android:src="@drawable/ic_menu" />

    <!-- Bouton config en haut à droite -->
    <FrameLayout
        android:id="@+id/top_right_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/btn_config"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Configuration"
            android:src="@drawable/ic_settings"
            app:tint="@color/white_70" />

        <View
            android:id="@+id/indicateur_gn"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/indicator_green"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Contenu principal centré -->
    <LinearLayout
        android:id="@+id/accueil_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="60dp"
        android:paddingTop="60dp">

        <!-- Logo : on utilise @drawable/logo_geonat (PNG avec fond transparent), généré
             à partir du foreground d'icône adaptative en supprimant son carré blanc opaque.
             Le @mipmap/ic_launcher_foreground d'origine contient un fond blanc plein qui
             apparaissait comme un carré derrière le logo. Inflater @mipmap/ic_launcher
             (AdaptiveIconDrawable) via android:src plante par ailleurs avec un NPE
             `Application.getResources() == null` sur certains appareils (cf. issue AOSP) —
             on évite ce chemin. -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="Logo GeoNat"
            android:src="@drawable/logo_geonat" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="GeoNat"
            android:textColor="@android:color/white"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tv_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/white_70"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Observations naturalistes"
            android:textColor="@color/white_70"
            android:textSize="15sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Boutons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Bouton nouvelle/reprendre sortie -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <Button
                        android:id="@+id/btn_nouveau_sortie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/green_85"
                        android:paddingVertical="18dp"
                        android:text="@string/saisie_multi_taxons"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textAllCaps="false" />

                    <View
                        android:id="@+id/indicateur_enregistrement"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/indicator_red"
                        android:visibility="gone" />
                </FrameLayout>

                <Button
                    android:id="@+id/btn_saisie_rapide"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/green_85"
                    android:text="@string/saisie_mono_taxons"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textAllCaps="false" />
            </LinearLayout>

            <!-- Bouton Suivis (module Monitoring GeoNature) -->
            <Button
                android:id="@+id/btn_suivis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/green_85"
                android:paddingVertical="16dp"
                android:text="Monitoring"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textAllCaps="false" />

            <!-- Switch enregistrer trace -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingTop="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_walk"
                    app:tint="@color/white_70" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Enregistrer la trace GPS"
                    android:textColor="@color/white_70"
                    android:textSize="15sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_trace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
