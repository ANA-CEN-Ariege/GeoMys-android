<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Carte (cachée en mode config, affichée quand la saisie démarre) -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Réticule (visible en mode actif) -->
    <FrameLayout
        android:id="@+id/reticule"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:background="#DDFF3333" />

        <View
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="#DDFF3333" />

        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:background="@drawable/reticule_circle" />

        <View
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_gravity="center"
            android:background="@drawable/reticule_dot" />
    </FrameLayout>

    <!-- Bouton retour -->
    <ImageButton
        android:id="@+id/btn_retour"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Retour"
        android:src="@drawable/ic_arrow_back"
        app:tint="?attr/colorOnSurface" />

    <!-- Compteur session (haut centre, mode actif) -->
    <TextView
        android:id="@+id/tv_compteur"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:background="@drawable/bandeau_dark"
        android:paddingHorizontal="14dp"
        android:paddingVertical="7dp"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Bouton fond de carte (visible uniquement en mode actif) -->
    <ImageButton
        android:id="@+id/btn_fond_carte"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:background="@drawable/btn_map_bg"
        android:contentDescription="Changer fond"
        android:src="@drawable/ic_map"
        android:visibility="gone" />

    <!-- ═══════════════════════════════════════════
         PANNEAU CONFIGURATION (état initial)
         ═══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/panneau_config"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_bg"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Titre -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_send"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saisie rapide multi-points"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Sélecteur de taxon -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="2dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_oiseau"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/oiseaux"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_mammifere"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/mammiferes2"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_reptile"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/reptiles2"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_batracien"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/amphibiens"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_invertebres"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/mollusques"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_poisson"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/poissons"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_insecte"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/insectes"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_fonge"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/champignons2"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_taxon_plante"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="10dp"
                        android:text=""
                        app:cornerRadius="8dp"
                        app:icon="@drawable/fleurs"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="24dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Switch nom scientifique -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_nom_sci"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Nom scientifique"
                android:textSize="13sp" />

            <!-- Espèce (optionnel) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_espece"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Espèce (optionnel)"
                app:endIconDrawable="@drawable/ic_mic"
                app:endIconMode="custom"
                app:endIconContentDescription="Dictée vocale">

                <AutoCompleteTextView
                    android:id="@+id/et_espece"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:completionThreshold="1"
                    android:inputType="textCapSentences" />
            </com.google.android.material.textfield.TextInputLayout>

            <ProgressBar
                android:id="@+id/taxref_progress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_taxref_statut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Bouton détails par défaut -->
            <Button
                android:id="@+id/btn_details_defaut"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Sexe, stade de vie, technique…" />

            <TextView
                android:id="@+id/tv_details_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Boutons Annuler / Démarrer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_annuler_saisie"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Annuler" />

                <Button
                    android:id="@+id/btn_demarrer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Démarrer la saisie →" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════
         PANNEAU ACTIF (enregistrement en cours)
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panneau_actif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/panel_bg"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:visibility="gone">

        <!-- Résumé des paramètres par défaut -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_taxon_icon_actif"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/oiseaux" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_resume_params"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_resume_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorControlNormal"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_modifier_params"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modifier" />
        </LinearLayout>

        <!-- Confirmation dernière observation (auto-dismiss 3s) -->
        <LinearLayout
            android:id="@+id/snack_confirmation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1A4CAF50"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@android:color/holo_green_dark" />

            <TextView
                android:id="@+id/tv_snack_espece"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@android:color/holo_green_dark"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_snack_modifier"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modifier"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Boutons d'action -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_terminer_rapide"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terminer" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Bouton re-centrage GPS -->
            <ImageButton
                android:id="@+id/btn_centrer_gps"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/btn_circle_white"
                android:contentDescription="Recentrer sur ma position"
                android:src="@drawable/ic_location_on" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btn_enregistrer_ici"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Enregistrer ici"
                android:src="@drawable/ic_add"
                app:backgroundTint="?attr/colorPrimary"
                app:fabSize="normal" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
