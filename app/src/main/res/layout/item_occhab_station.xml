<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_infos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?attr/colorControlNormal"
            android:textSize="12sp" />

        <!-- État d'envoi : « ✅ Envoyée » ou « ⚠ <erreur> ». -->
        <TextView
            android:id="@+id/tv_etat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_envoyer"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Envoyer au serveur"
        android:src="@drawable/ic_send"
        android:visibility="gone"
        app:tint="@color/colorSecondary" />

    <ImageButton
        android:id="@+id/btn_editer"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Modifier la station"
        android:src="@drawable/ic_edit"
        android:visibility="gone"
        app:tint="?attr/colorPrimary" />

    <ImageButton
        android:id="@+id/btn_supprimer"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Supprimer"
        android:src="@drawable/ic_delete"
        app:tint="@android:color/holo_red_light" />
</LinearLayout>
