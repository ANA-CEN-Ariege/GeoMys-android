<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <include
            android:id="@+id/bandeau_saisie"
            layout="@layout/view_bandeau_saisie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:paddingEnd="64dp"
            android:text="Caractérisation de l'occurrence"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Champs de nomenclature de l'occurrence rendus dynamiquement (OcctaxFieldsRenderer),
             d'après le registre filtré par la config serveur settings.json (visibilité/ordre). -->
        <LinearLayout
            android:id="@+id/ll_caracterisation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Section « Avancé » occurrence (pilotée par form_fields, repliée par défaut) : déterminateur,
             nomenclatures avancées, preuves, commentaire — rendus dynamiquement selon la config serveur. -->
        <LinearLayout
            android:id="@+id/ll_caracterisation_form_fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Champs additionnels niveau OCCURRENCE uniquement. Les champs niveau RELEVE
             sont édités au niveau de la session via le bouton "Détails du relevé" de
             SaisieObservationFragment (ils sont partagés entre toutes les espèces). -->
        <TextView
            android:id="@+id/tv_label_add_occurrence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="2dp"
            android:text="Champs additionnels (occurrence)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ll_add_occurrence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
    </ScrollView>

    <!-- Bouton de validation en haut à droite : même cercle vert + coche que la saisie
         multi-taxons rapide et la config (drawable coche.xml = cercle plein vert avec
         coche blanche au centre). -->
    <ImageButton
        android:id="@+id/btn_ok"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Valider"
        android:scaleType="fitCenter"
        android:src="@drawable/coche" />
</FrameLayout>
