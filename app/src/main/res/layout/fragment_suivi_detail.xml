<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="64dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Fil d'Ariane "Suivis › Protocole" (le protocole = écran courant, non cliquable).
                 Cadre arrondi (@drawable/bg_fil_ariane) + ombre. -->
            <TextView
                android:id="@+id/tv_fil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_fil_ariane"
                android:backgroundTint="?attr/colorSurfaceVariant"
                android:elevation="6dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:ignore="UnusedAttribute"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tv_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Jeu(x) de données associé(s) au protocole. Affiché en italique sous la
                 description. Masqué si aucun dataset cache ne correspond. -->
            <TextView
                android:id="@+id/tv_datasets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:textStyle="italic"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_nb_sites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progress_detail"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp" />

            <TextView
                android:id="@+id/tv_erreur_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@android:color/holo_red_dark"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/ll_sites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btn_retour"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Retour"
        android:src="@drawable/ic_arrow_back"
        app:tint="?attr/colorOnSurface" />
</FrameLayout>