<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Plus de flèche retour : le bandeau de navigation "🏠 › Monitoring" (icône maison)
         assure le retour à l'accueil. -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <include
            android:id="@+id/bandeau_saisie"
            layout="@layout/view_bandeau_saisie"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitoring"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="12dp"
            android:text="Protocoles disponibles sur le serveur"
            android:textColor="@android:color/darker_gray"
            android:textSize="13sp" />

        <!-- Bandeau cliquable affichant le nombre de saisies en attente d'envoi.
             Tap → écran SaisiesEnAttenteFragment. Visible uniquement si count > 0. -->
        <Button
            android:id="@+id/btn_saisies_attente"
            style="@style/Widget.GeoMys.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Données en attente d'envoi"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progress_suivis"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_erreur_suivis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp"
            android:visibility="gone" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/ll_modules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>
</FrameLayout>
